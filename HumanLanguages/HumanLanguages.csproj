<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>A database of human language names in many languages, with language and locale-variation codes.</Description>
    <PackageLicenseExpression>GPL-3.0-only</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/prmeyn/HumanLanguages</PackageProjectUrl>
    <RepositoryUrl>https://github.com/prmeyn/HumanLanguages</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>
<ItemGroup>
 <None Include="../README.md" Pack="true" PackagePath="\" />
</ItemGroup>
</Project>
